---
const { i18n } = Astro.props
---

<div class="grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
  <div class="space-y-4">
    {i18n.LEARNING.AREAS.map((area) => (
      <article class="rounded-[2rem] border border-black/10 bg-white/65 p-5 shadow-sm backdrop-blur dark:border-white/10 dark:bg-white/5">
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white">{area.title}</h3>
        <p class="mt-2 text-sm leading-7 text-gray-700 dark:text-gray-300 text-pretty">
          {area.description}
        </p>
        <p class="mt-3 text-xs uppercase tracking-[0.16em] text-gray-500 dark:text-gray-400">
          {area.courses}
        </p>
      </article>
    ))}
  </div>

  <div class="space-y-4">
    <article class="rounded-[2rem] border border-black/10 bg-gradient-to-br from-amber-100/80 via-white to-sky-100/70 p-6 shadow-sm dark:border-white/10 dark:from-amber-500/10 dark:via-zinc-950 dark:to-sky-500/10">
      <p class="text-xs uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400">
        {i18n.LEARNING.CERTIFICATIONS_LABEL}
      </p>
      <h3 class="mt-2 text-2xl font-semibold text-gray-900 dark:text-white text-balance">
        {i18n.LEARNING.CERT_TITLE}
      </h3>
      <p class="mt-3 text-sm leading-7 text-gray-700 dark:text-gray-300 text-pretty">
        {i18n.LEARNING.CERT_DESCRIPTION}
      </p>
      <div class="mt-4 inline-flex rounded-full border border-black/10 px-3 py-1 text-xs font-medium text-gray-700 dark:border-white/10 dark:text-gray-300">
        {i18n.LEARNING.CERT_META}
      </div>
    </article>

    <article class="rounded-[2rem] border border-black/10 bg-white/65 p-6 shadow-sm backdrop-blur dark:border-white/10 dark:bg-white/5">
      <p class="text-xs uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400">
        {i18n.LEARNING.DEGREE_LABEL}
      </p>
      <h3 class="mt-2 text-2xl font-semibold text-gray-900 dark:text-white text-balance">
        {i18n.LEARNING.DEGREE_TITLE}
      </h3>
      <p class="mt-3 text-sm leading-7 text-gray-700 dark:text-gray-300 text-pretty">
        {i18n.LEARNING.DEGREE_DESCRIPTION}
      </p>
    </article>
  </div>
</div>
