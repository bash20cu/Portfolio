---
import GitHub from "./icons/GitHub.astro";
import Link from "./icons/Link.astro";
import LinkButton from "./LinkButton.astro";
import ArchitecturePreview from "./ArchitecturePreview.astro";

const { projects, i18n } = Astro.props;

const sections = [
  {
    key: "featured",
    title: i18n?.PROJECTS?.FEATURED_TITLE || "Featured work",
    intro: i18n?.PROJECTS?.FEATURED_INTRO || "Projects that best represent my current positioning.",
  },
  {
    key: "private",
    title: i18n?.PROJECTS?.PRIVATE_TITLE || "Private systems",
    intro: i18n?.PROJECTS?.PRIVATE_INTRO || "Selected internal tooling and private case studies.",
  },
  {
    key: "academic",
    title: i18n?.PROJECTS?.ACADEMIC_TITLE || "Academic builds",
    intro: i18n?.PROJECTS?.ACADEMIC_INTRO || "University work that still matters to my technical story.",
  },
];
---

<div class="space-y-16">
  {sections.map((section) => {
    const sectionProjects = projects.filter((project) => project.section === section.key);

    if (sectionProjects.length === 0) return null;

    return (
      <section class="space-y-6">
        <div class="max-w-3xl">
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-sky-500 dark:text-sky-300">
            {section.title}
          </p>
          <p class="mt-3 text-pretty text-gray-700 dark:text-gray-300">
            {section.intro}
          </p>
        </div>

        <div class="space-y-8">
          {section.key === "featured" ? (
            <div class="embla relative" id="projects-carousel">
              <div class="embla__container">
                {sectionProjects.map((project) => (
                  <div class="embla__slide">
                    <article class="group relative overflow-hidden rounded-[2rem] border border-slate-200/80 bg-white/85 shadow-[0_24px_80px_-48px_rgba(15,23,42,0.45)] backdrop-blur dark:border-white/10 dark:bg-white/5">
                      <div class="min-w-0 px-4 py-5 sm:px-6 sm:py-6 lg:px-8">
                        <div class="flex flex-wrap items-center gap-3 text-sm">
                          <span class="rounded-full border border-sky-400/30 bg-sky-500/10 px-3 py-1 font-semibold text-sky-700 dark:text-sky-300">
                            {project.type}
                          </span>
                          <span class="hidden rounded-full border border-slate-300/80 bg-white px-3 py-1 text-xs font-medium text-slate-600 dark:border-white/10 dark:bg-white/10 dark:text-slate-300 lg:inline-flex">
                            {i18n?.PROJECTS?.VISUAL_HINT || "Hover to preview visual"}
                          </span>
                          {(project.company || project.period) && (
                            <span class="text-slate-500 dark:text-slate-400">
                              {[project.company, project.period].filter(Boolean).join(" · ")}
                            </span>
                          )}
                        </div>

                        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-slate-900 dark:text-slate-100 sm:text-3xl">
                          {project.title}
                        </h3>

                        {project.role && (
                          <p class="mt-2 text-sm font-medium text-slate-500 dark:text-slate-400">{project.role}</p>
                        )}

                        <p class="mt-4 max-w-4xl text-base font-medium leading-7 text-slate-800 dark:text-slate-100 sm:text-lg sm:leading-8">
                          {project.summary}
                        </p>

                        <p class="mt-4 max-w-4xl text-pretty text-sm leading-7 text-slate-700 dark:text-slate-300 sm:text-base sm:leading-8">
                          {project.description}
                        </p>

                        <ArchitecturePreview architecture={project.architecture} />

                        <div class="mt-6">
                          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">
                            {i18n?.PROJECTS?.IMPACT || "Impact"}
                          </p>
                          <ul class="mt-3 grid gap-3 text-sm leading-6 text-slate-700 dark:text-slate-300 xl:grid-cols-2">
                            {project.impact.map((item) => (
                              <li class="rounded-2xl border border-slate-200/80 bg-slate-50/80 px-4 py-3 dark:border-white/10 dark:bg-white/5">
                                {item}
                              </li>
                            ))}
                          </ul>
                        </div>

                        <ul class="mt-6 flex flex-wrap gap-2">
                          {project.topics.map((tag) => (
                            <li>
                              <span class="rounded-full border border-slate-300/80 bg-white px-3 py-1 text-xs font-medium text-slate-700 dark:border-white/10 dark:bg-white/10 dark:text-slate-200">
                                {tag}
                              </span>
                            </li>
                          ))}
                        </ul>

                        {project.disclaimer && (
                          <p class="mt-5 rounded-2xl border border-amber-400/30 bg-amber-500/10 px-4 py-3 text-sm leading-6 text-amber-800 dark:text-amber-200">
                            {project.disclaimer}
                          </p>
                        )}

                        {(project.github || project.link) && (
                          <footer class="mt-6 flex flex-wrap gap-3">
                            {project.github && (
                              <LinkButton href={project.github}>
                                <GitHub class="size-5" />
                                {i18n?.PROJECTS?.CODE || "Code"}
                              </LinkButton>
                            )}
                            {project.link && (
                              <LinkButton href={project.link}>
                                <Link class="size-4" />
                                {i18n?.PROJECTS?.PREVIEW || "Preview"}
                              </LinkButton>
                            )}
                          </footer>
                        )}
                      </div>

                      <div class="pointer-events-none absolute right-4 top-4 hidden w-[220px] translate-y-2 opacity-0 transition-all duration-200 ease-out group-hover:translate-y-0 group-hover:opacity-100 2xl:block">
                        <div class="overflow-hidden rounded-[1.4rem] border border-white/10 bg-slate-950/95 p-3 shadow-2xl">
                          <div class="flex aspect-[16/10] items-center justify-center overflow-hidden rounded-[1rem] border border-white/10 bg-slate-900/80 p-3">
                            <img
                              alt={project.title}
                              width="1200"
                              height="760"
                              class="max-h-full w-auto max-w-full object-contain object-center opacity-95"
                              loading="lazy"
                              src={project.image}
                            />
                          </div>
                        </div>
                      </div>
                    </article>
                  </div>
                ))}
              </div>

            </div>
          ) : (
            <div class="grid gap-8 xl:grid-cols-2">
              {sectionProjects.map((project) => (
                <article class="group relative grid overflow-hidden rounded-[2rem] border border-slate-200/80 bg-white/85 shadow-[0_24px_80px_-48px_rgba(15,23,42,0.45)] backdrop-blur dark:border-white/10 dark:bg-white/5">
                  <div class="min-w-0 px-4 py-5 sm:px-6 sm:py-6">
                    <div class="flex flex-wrap items-center gap-3 text-sm">
                      <span class="rounded-full border border-sky-400/30 bg-sky-500/10 px-3 py-1 font-semibold text-sky-700 dark:text-sky-300">
                        {project.type}
                      </span>
                      <span class="hidden rounded-full border border-slate-300/80 bg-white px-3 py-1 text-xs font-medium text-slate-600 dark:border-white/10 dark:bg-white/10 dark:text-slate-300 lg:inline-flex">
                        {i18n?.PROJECTS?.VISUAL_HINT || "Hover to preview visual"}
                      </span>
                      {(project.company || project.period) && (
                        <span class="text-slate-500 dark:text-slate-400">
                          {[project.company, project.period].filter(Boolean).join(" · ")}
                        </span>
                      )}
                    </div>

                    <h3 class="mt-4 text-2xl font-semibold tracking-tight text-slate-900 dark:text-slate-100">
                      {project.title}
                    </h3>

                    {project.role && (
                      <p class="mt-2 text-sm font-medium text-slate-500 dark:text-slate-400">{project.role}</p>
                    )}

                    <p class="mt-4 text-base font-medium leading-7 text-slate-800 dark:text-slate-100 sm:text-lg sm:leading-8">
                      {project.summary}
                    </p>

                    <p class="mt-4 text-pretty text-sm leading-7 text-slate-700 dark:text-slate-300 sm:text-base sm:leading-8">
                      {project.description}
                    </p>

                    <ArchitecturePreview architecture={project.architecture} />

                    <div class="mt-6">
                      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">
                        {i18n?.PROJECTS?.IMPACT || "Impact"}
                      </p>
                      <ul class="mt-3 grid gap-3 text-sm leading-6 text-slate-700 dark:text-slate-300">
                        {project.impact.map((item) => (
                          <li class="rounded-2xl border border-slate-200/80 bg-slate-50/80 px-4 py-3 dark:border-white/10 dark:bg-white/5">
                            {item}
                          </li>
                        ))}
                      </ul>
                    </div>

                    <ul class="mt-6 flex flex-wrap gap-2">
                      {project.topics.map((tag) => (
                        <li>
                          <span class="rounded-full border border-slate-300/80 bg-white px-3 py-1 text-xs font-medium text-slate-700 dark:border-white/10 dark:bg-white/10 dark:text-slate-200">
                            {tag}
                          </span>
                        </li>
                      ))}
                    </ul>

                    {project.disclaimer && (
                      <p class="mt-5 rounded-2xl border border-amber-400/30 bg-amber-500/10 px-4 py-3 text-sm leading-6 text-amber-800 dark:text-amber-200">
                        {project.disclaimer}
                      </p>
                    )}

                    {(project.github || project.link) && (
                      <footer class="mt-6 flex flex-wrap gap-3">
                        {project.github && (
                          <LinkButton href={project.github}>
                            <GitHub class="size-5" />
                            {i18n?.PROJECTS?.CODE || "Code"}
                          </LinkButton>
                        )}
                        {project.link && (
                          <LinkButton href={project.link}>
                            <Link class="size-4" />
                            {i18n?.PROJECTS?.PREVIEW || "Preview"}
                          </LinkButton>
                        )}
                      </footer>
                    )}
                  </div>

                  <div class="pointer-events-none absolute right-4 top-4 hidden w-[210px] translate-y-2 opacity-0 transition-all duration-200 ease-out group-hover:translate-y-0 group-hover:opacity-100 2xl:block">
                    <div class="overflow-hidden rounded-[1.4rem] border border-white/10 bg-slate-950/95 p-3 shadow-2xl">
                      <div class="flex aspect-[16/10] items-center justify-center overflow-hidden rounded-[1rem] border border-white/10 bg-slate-900/80 p-3">
                        <img
                          alt={project.title}
                          width="1200"
                          height="760"
                          class="max-h-full w-auto max-w-full object-contain object-center opacity-95"
                          loading="lazy"
                          src={project.image}
                        />
                      </div>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          )}
        </div>
      </section>
    );
  })}
</div>

<style>
  .embla {
    overflow: hidden;
  }

  .embla__container {
    display: flex;
    gap: 1.5rem;
  }

  .embla__slide {
    flex: 0 0 100%;
    min-width: 0;
  }
</style>

<script>
  import EmblaCarousel from "embla-carousel";
  import Autoplay from "embla-carousel-autoplay";

  const initProjectsCarousel = () => {
    const emblaNode = document.querySelector("#projects-carousel");
    if (!emblaNode) return;

    const prevBtn = document.querySelector("#projects-header-prev");
    const nextBtn = document.querySelector("#projects-header-next");
    let lastAutoAdvanceAt = 0;

    const emblaApi = EmblaCarousel(emblaNode, { loop: true }, [
      Autoplay({ delay: 12000, stopOnInteraction: true }),
    ]);

    if (prevBtn) prevBtn.onclick = () => emblaApi.scrollPrev();
    if (nextBtn) nextBtn.onclick = () => emblaApi.scrollNext();

     emblaNode.addEventListener("architecture:cycle-complete", () => {
      const now = Date.now();
      if (now - lastAutoAdvanceAt < 1800) return;
      lastAutoAdvanceAt = now;
      emblaApi.scrollNext();
    });
  };

  document.addEventListener("astro:page-load", initProjectsCarousel);
</script>
