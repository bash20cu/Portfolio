---
// CVDownload.astro
const lang: 'es' | 'en' = (Astro.props?.lang as 'es' | 'en') || 'es';
const label = Astro.props?.label as string | undefined;

const fileMap = {
  es: '/files/cv_es_data_analist.pdf',
  en: '/files/cv_en_data_analist.pdf',
};

const fileUrl = fileMap[lang] || fileMap.es;
import Badge from "../components/Badge.astro"
---

<div class="flex flex-col gap-2">
  <Badge>

  <a
    href={fileUrl}
    target="_blank"
    rel="noopener noreferrer"
  >
    {label || (lang === 'es' ? 'Ver / Descargar CV (ES)' : 'View / Download CV (EN)')}
  </a>
      
  </Badge>
</div>
