---
const { architecture } = Astro.props;
---

<div class="arch-preview mt-6 rounded-[1.5rem] border border-slate-200/80 bg-slate-50/80 p-4 dark:border-white/10 dark:bg-white/5" data-arch-steps={architecture.steps.length}>
  <div class="mb-3 flex items-center justify-between gap-3">
    <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">
      {architecture.label}
    </p>
    <span class="text-[11px] uppercase tracking-[0.22em] text-sky-600 dark:text-sky-300">
      Flow
    </span>
  </div>

  <div class="arch-track grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
    {architecture.steps.map((step, index) => (
      <article class="arch-node rounded-[1.1rem] border border-slate-200 bg-white px-4 py-3 transition-all duration-300 dark:border-white/10 dark:bg-slate-950/40" data-index={index}>
        <div class="flex items-center gap-3">
          <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-sky-500/10 text-xs font-bold text-sky-700 dark:text-sky-300">
            {index + 1}
          </span>
          <h4 class="text-sm font-semibold text-slate-900 dark:text-slate-100">{step.title}</h4>
        </div>
        <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">{step.detail}</p>
      </article>
    ))}
  </div>
</div>

<style>
  .arch-node {
    position: relative;
  }

  @media (min-width: 1280px) {
    .arch-node:not(:last-child)::after {
      content: "";
      position: absolute;
      top: 50%;
      right: -14px;
      width: 18px;
      height: 2px;
      background: linear-gradient(90deg, rgba(14,165,233,0.8), rgba(14,165,233,0.15));
      transform: translateY(-50%);
    }
  }

  .arch-node.is-active {
    border-color: rgba(14, 165, 233, 0.55);
    box-shadow: 0 0 0 1px rgba(14, 165, 233, 0.18), 0 18px 38px -28px rgba(14, 165, 233, 0.45);
    transform: translateY(-2px);
  }

  @media (max-width: 639px) {
    .arch-preview {
      padding: 0.875rem;
    }
  }
</style>

<script>
  const initArchitecturePreview = () => {
    const previews = document.querySelectorAll(".arch-preview");

    previews.forEach((preview) => {
      const nodes = Array.from(preview.querySelectorAll(".arch-node"));
      if (!nodes.length) return;

      let current = 0;
      const totalSteps = Number(preview.getAttribute("data-arch-steps")) || nodes.length;
      const paint = (index) => {
        nodes.forEach((node, nodeIndex) => {
          node.classList.toggle("is-active", nodeIndex === index);
        });
      };

      paint(0);

      const intervalId = window.setInterval(() => {
        const next = (current + 1) % nodes.length;
        if (current === totalSteps - 1) {
          preview.dispatchEvent(
            new CustomEvent("architecture:cycle-complete", {
              bubbles: true,
            })
          );
        }
        current = next;
        paint(current);
      }, 2200);

      preview.addEventListener("mouseenter", () => window.clearInterval(intervalId), { once: true });
    });
  };

  document.addEventListener("astro:page-load", initArchitecturePreview);
</script>
