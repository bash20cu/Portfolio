---
const { i18n } = Astro.props
---

<div class="space-y-5">
  {i18n.JOURNEY.STEPS.map((step, index) => (
    <article class="grid gap-4 rounded-[2rem] border border-black/10 bg-white/65 p-5 shadow-sm backdrop-blur dark:border-white/10 dark:bg-white/5 md:grid-cols-[120px_1fr] md:items-start">
      <div class="text-sm font-medium uppercase tracking-[0.18em] text-gray-500 dark:text-gray-400">
        {step.period || `0${index + 1}`}
      </div>
      <div>
        <h3 class="text-2xl font-semibold text-gray-900 dark:text-white text-balance">
          {step.title}
        </h3>
        <p class="mt-2 text-sm leading-7 text-gray-700 dark:text-gray-300 text-pretty">
          {step.description}
        </p>
      </div>
    </article>
  ))}
</div>
