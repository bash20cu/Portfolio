---
const { i18n } = Astro.props
---

<div class="grid gap-5 xl:grid-cols-2">
  {i18n.JOURNEY.STEPS.map((step, index) => (
    <article class="grid gap-4 rounded-[2rem] border border-black/10 bg-white/65 p-5 shadow-sm backdrop-blur dark:border-white/10 dark:bg-white/5 md:grid-cols-[9.5rem_minmax(0,1fr)] md:gap-6 md:items-start">
      <div class="max-w-[12ch] text-sm font-medium uppercase leading-6 tracking-[0.18em] text-gray-500 dark:text-gray-400">
        {step.period || `0${index + 1}`}
      </div>
      <div class="min-w-0">
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white text-balance sm:text-2xl">
          {step.title}
        </h3>
        <p class="mt-2 indent-6 text-sm leading-7 text-gray-700 [text-align:justify] dark:text-gray-300 text-pretty">
          {step.description}
        </p>
      </div>
    </article>
  ))}
</div>
