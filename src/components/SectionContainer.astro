---
const { class: className, id, wide = false } = Astro.props
const sizeClass = wide
  ? "md:max-w-5xl lg:max-w-7xl 2xl:max-w-[90rem]"
  : "md:max-w-3xl lg:max-w-5xl 2xl:max-w-6xl"
---

<section
  id={id}
  data-section={id}
  class={`section ${className} scroll-m-20 w-full mx-auto container ${sizeClass}`}
>
  <slot />
</section>
