---
import LinkInline from "./LinkInline.astro"

interface Props {
  title: string
  company: string
  description: string
  link?: string
  date: string
  index?: number
}

const { title, company, description, link, date, index } = Astro.props
---

<article class="relative overflow-hidden rounded-[2rem] border border-black/10 bg-white/65 p-5 shadow-sm backdrop-blur dark:border-white/10 dark:bg-white/5 sm:p-6">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-sky-400/60 to-transparent"></div>

  <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
    <div class="min-w-0">
      <div class="flex flex-wrap items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-sky-600 dark:text-sky-300">
        <span class="rounded-full border border-sky-400/30 bg-sky-500/10 px-2 py-1">
          {`Node ${String(index || 1).padStart(2, "0")}`}
        </span>
        <span>{company}</span>
      </div>

      <h3 class="mt-3 text-lg font-semibold leading-tight text-slate-900 dark:text-slate-100 sm:text-xl">
        {title}
      </h3>

      <h4 class="mt-1 text-sm font-medium text-slate-500 dark:text-slate-400">{company}</h4>
    </div>
    <time class="shrink-0 rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-sm font-mono text-slate-600 dark:border-white/10 dark:bg-white/5 dark:text-slate-300">{date}</time>
  </div>

  <div class="mt-4 rounded-[1.25rem] border border-slate-200/80 bg-slate-50/70 p-4 dark:border-white/10 dark:bg-white/[0.03]">
    <p class="indent-6 text-pretty text-sm leading-7 text-gray-600 [text-align:justify] dark:text-gray-300">
      {description}
    </p>
  </div>

  <div class="mt-4 grid gap-3 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-center">
    <div class="rounded-[1rem] border border-slate-200/80 bg-white/70 px-3 py-2 text-[11px] font-medium uppercase tracking-[0.18em] text-slate-500 dark:border-white/10 dark:bg-white/[0.03] dark:text-slate-400">
      Input -> analysis -> action -> business context
    </div>

    {link && (
      <div>
        <LinkInline href={link}>
          Saber más{" "}
          <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 icon icon-tabler icon-tabler-chevron-right inline-block"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              fill="none"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <>
                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                <path d="M9 6l6 6l-6 6" />
              </>
            </svg>
        </LinkInline>
      </div>
    )}
  </div>

  <div class="pointer-events-none absolute right-5 top-5 hidden h-16 w-16 rounded-full border border-sky-400/10 bg-sky-500/5 blur-2xl lg:block"></div>

  <div class="sr-only text-gray-600 dark:text-gray-300 text-pretty flex-grow">
    {description}
  </div>
</article>
